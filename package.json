{
  "name": "tamagit",
  "version": "0.1.0",
  "description": "Turn your Claude Code activity into an RPG — XP, streaks, achievements, and a pet that grows. Local-first, zero runtime dependencies.",
  "keywords": [
    "claude-code",
    "gamification",
    "rpg",
    "tamagotchi",
    "developer-tools",
    "xp",
    "streak"
  ],
  "license": "MIT",
  "author": "Dalgureum Lab",
  "homepage": "https://github.com/abdc06/tamagit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdc06/tamagit.git"
  },
  "bugs": {
    "url": "https://github.com/abdc06/tamagit/issues"
  },
  "type": "module",
  "bin": {
    "tamagit": "./src/cli.ts"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "LICENSE"
  ],
  "scripts": {
    "start": "node --disable-warning=ExperimentalWarning src/cli.ts",
    "sync": "node --disable-warning=ExperimentalWarning src/cli.ts sync",
    "stats": "node --disable-warning=ExperimentalWarning src/cli.ts stats",
    "serve": "node --disable-warning=ExperimentalWarning src/cli.ts serve",
    "test": "node --disable-warning=ExperimentalWarning --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "install:auto": "node --disable-warning=ExperimentalWarning src/cli.ts install",
    "status": "node --disable-warning=ExperimentalWarning src/cli.ts status"
  },
  "private": true,
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "5.9"
  }
}
